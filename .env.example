# --- Database ---
DB_NAME=portcullis
DB_USER=postgres
DB_PASSWORD=portcullis
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?schema=public

# --- Gateway ---
# The domain where the manager UI is reachable
PORTCULLIS_DOMAIN=staging.yourdomain.com
# SSL Mode: internal (self-signed) or acme (real certificates)
CADDY_TLS_MODE=internal
# URL of the Caddy Admin API (internal networking handles this in Docker)
CADDY_ADMIN_API=http://localhost:2019

# --- Security ---
# Generated secret for session management
NEXTAUTH_SECRET=generate_one_locally
